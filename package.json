{
  "name": "philtv-js",
  "version": "2.0.0-beta.0",
  "description": "A simple library to pair and interact with Philips TV",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "philtv-js": "./dist/bin/pairing.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./constants": {
      "types": "./dist/constants.d.mts",
      "import": "./dist/constants.mjs",
      "require": "./dist/constants.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "watch": "pnpm build --watch",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:generate": "pnpm typedoc:generate && pnpm docs:build",
    "docs:preview": "vitepress preview docs",
    "format": "pnpm biome format",
    "lint": "pnpm biome lint",
    "lint:check": "pnpm biome check",
    "typedoc:generate": "typedoc",
    "release": "pnpm release-it",
    "release:test": "pnpm release-it --dry-run",
    "test": "vitest ."
  },
  "dependencies": {
    "consola": "3.4.2",
    "radash": "12.1.1",
    "urllib": "4.9.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@release-it/conventional-changelog": "10.0.6",
    "@types/node": "25.5.0",
    "@types/validator": "13.15.10",
    "release-it": "19.2.4",
    "tsdown": "^0.21.2",
    "tsx": "4.21.0",
    "typedoc": "0.28.17",
    "typedoc-plugin-markdown": "4.10.0",
    "typedoc-vitepress-theme": "1.1.2",
    "typescript": "5.9.3",
    "vitepress": "1.6.4",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "ambilight",
    "android-tv",
    "jointspace",
    "philips",
    "philtv"
  ],
  "author": "Clément BERARD <contact@berard.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clement-berard/philtv-js.git"
  },
  "bugs": {
    "url": "https://github.com/clement-berard/philtv-js/issues"
  },
  "homepage": "https://github.com/clement-berard/philtv-js#readme",
  "files": [
    "dist"
  ],
  "pnpm": {
    "overrides": {
      "cross-spawn": "^7.0.5"
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "vue-demi"
    ]
  }
}
